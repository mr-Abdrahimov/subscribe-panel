# ══════════════════════════════════════════════════════════════════════════════
# Subscribe Panel — шаблон .env для docker compose
# Скопируйте в .env и заполните все значения перед запуском:
#   cp .env.example .env
#   docker compose up -d
# ══════════════════════════════════════════════════════════════════════════════

# ─── Docker образы ────────────────────────────────────────────────────────────
# Репозиторий GitHub (owner/repo), используется для ссылок на GHCR-образы.
# Пример: myuser/subscribe-panel
GITHUB_REPO=mr-abdrahimov/subscribe-panel

# Тег образа: latest, main, v1.2.3 и т.д.
IMAGE_TAG=latest

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_DATABASE=subscribe_panel

# ─── Redis ────────────────────────────────────────────────────────────────────
# ОБЯЗАТЕЛЬНО замените на сильный пароль.
REDIS_PASSWORD=change_me_redis_password

# ─── Backend: порты на хосте (nginx делает proxy на эти адреса) ───────────────
BACKEND_PORT=3000
FRONTEND_PORT=3001

# ─── Backend: Auth / JWT ──────────────────────────────────────────────────────
# Генерация: openssl rand -hex 64
JWT_SECRET=change_me_jwt_secret_very_long_random_string
JWT_EXPIRES_IN=7d

# ─── Backend: CORS / публичные URL ───────────────────────────────────────────
# Origin фронтенда — используется для CORS, абсолютных URL подписок и og:image.
# Должен совпадать с публичным адресом сайта (с https://).
# Пример: https://panel.example.com
FRONTEND_ORIGIN=https://panel.example.com

# Сегмент пути для crypto happ:// ссылок (≠ "sub").
# Этот же сегмент автоматически передаётся во фронтенд как NUXT_PUBLIC_SUBSCRIPTION_CRYPTO_PATH.
SUBSCRIPTION_CRYPTO_PATH_SEGMENT=sub2128937123

# Подробный JSON-лог входящих GET /api/public/sub/… (все HTTP-заголовки, query, IP, via=crypto-page). Отключить: false
SUBSCRIPTION_INCOMING_HTTP_LOG=true

# ─── Backend: начальный администратор ────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=System Admin

# ─── Backend: Telegram уведомления ───────────────────────────────────────────
# true — отправлять уведомление при первом доступе с нового HWID.
TELEGRAM_NOTIFY_SUBSCRIPTION_ACCESS=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Backend: Swagger ─────────────────────────────────────────────────────────
SWAGGER_PATH=docs
SWAGGER_TITLE=Subscribe Panel API
SWAGGER_DESCRIPTION=
SWAGGER_VERSION=1.0.0

# ─── Backend: Bull Board (мониторинг очередей) ───────────────────────────────
BULL_BOARD_ENABLED=false
# Токен доступа: ?token=… или заголовок x-bull-board-token
BULL_BOARD_TOKEN=

# ─── Frontend: публичный URL API (виден браузеру) ─────────────────────────────
# Должен быть доступен снаружи (если nginx проксирует /api → backend,
# то здесь указываете https://panel.example.com/api или отдельный домен).
NUXT_PUBLIC_API_BASE_URL=https://panel.example.com/api
