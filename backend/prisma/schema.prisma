generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ConnectStatus {
  ACTIVE
  INACTIVE
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  name      String?
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscription {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  title        String
  url          String
  lastFetchedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  connects     Connect[]
}

model Connect {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  originalName   String
  name           String
  groupNames     String[]     @default([])
  raw            String
  protocol       String
  status         ConnectStatus @default(ACTIVE)
  hidden         Boolean      @default(false)
  tags           String[]
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  subscriptionId String       @db.ObjectId
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
}

model Group {
  id                        String   @id @default(auto()) @map("_id") @db.ObjectId
  name                      String   @unique
  /// Название профиля подписки: /sub и profile-title; фрагмент # в ленте — всегда Connect.name
  subscriptionDisplayName   String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model PanelUser {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  code      String   @unique
  groupName String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Ссылки для страницы /sub: в urlTemplate каждое {link} → полный URL https://origin/sub/CODE (origin из env); {link} необязателен
model SubscriptionAppLink {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  urlTemplate String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

