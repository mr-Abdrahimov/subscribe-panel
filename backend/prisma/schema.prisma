generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ConnectStatus {
  ACTIVE
  INACTIVE
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  name      String?
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscription {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  title        String
  /// Название из ответа ленты при синке: заголовок profile-title (в т.ч. base64:…), иначе комментарий «# …» в раскодированном теле; null — провайдер не прислал
  fetchedProfileTitle String?
  /// Окончание подписки из ответа ленты: subscription-userinfo (expire=…), null — нет данных или expire=0 (без срока)
  fetchedSubscriptionExpiresAt DateTime?
  /// Использованный трафик (байты): upload + download из subscription-userinfo; null — нет данных
  fetchedTrafficUsedBytes String?
  /// Для какого момента окончания (Unix-секунда) уже отправляли в Telegram предупреждение «осталось < 10 ч»
  telegramExpiryWarningSentForExpiresAt DateTime?
  /// Саб ссылка: URL ленты, по которому получают коннекты
  url          String
  /// Ссылка на источник (откуда получена саб ссылка), необязательно
  sourceUrl    String?
  lastFetchedAt DateTime?
  /// Интервал автообновления коннектов (минуты), null — только вручную; минимум 5 на уровне API
  fetchIntervalMinutes Int?
  /// Заголовок User-Agent при GET запросе к url (кнопка «Получить коннекты» и очередь)
  userAgent    String?
  /// Доп. заголовок X-HWID при GET к url, если задан
  hwid         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  connects     Connect[]
}

model Connect {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  originalName   String
  name           String
  groupNames     String[]     @default([])
  raw            String
  /// Ключ normalizedConnectIdentity(raw) на момент последней синхронизации из подписки (устаревшие записи без поля сопоставляются только по normalize(raw))
  identityKey    String?
  protocol       String
  status         ConnectStatus @default(ACTIVE)
  hidden         Boolean      @default(false)
  tags           String[]
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  subscriptionId String       @db.ObjectId
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
}

model Group {
  id                        String   @id @default(auto()) @map("_id") @db.ObjectId
  name                      String   @unique
  /// Главная группа: у одного коннекта не может быть двух групп с этим флагом одновременно (страница «Коннекты»)
  isMainGroup               Boolean  @default(false)
  /// Порядок строки в таблице групп панели (как sortOrder у коннектов)
  sortOrder                 Int      @default(0)
  /// Название профиля подписки: /sub и profile-title; фрагмент # в ленте — всегда Connect.name
  subscriptionDisplayName   String?
  /// Текст объявления Happ для пользователей этой группы (#announce / announce); null — наследовать из глобальных настроек панели
  subscriptionAnnounce      String?
  /// Интервал автообновления Happ (часы); null — наследовать из глобальных настроек панели
  profileUpdateInterval     Int?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model PanelUser {
  id                   String                 @id @default(auto()) @map("_id") @db.ObjectId
  name                 String
  code                 String                 @unique
  /// Группы ленты: коннекты из объединения групп; дубликаты строк в подписке не выдаются
  groupNames           String[]               @default([])
  /// Порядок групп в ленте и включение: [{ "name": "…", "include": true }]; null — все groupNames по порядку, все включены
  subscriptionGroupPrefs Json?
  enabled              Boolean                @default(true)
  /// Если true — base64-подписка отдаётся любому User-Agent; иначе только при UA, начинающемся с «Happ»
  allowAllUserAgents   Boolean                @default(false)
  /// Если true — без HWID в запросе отдаётся заглушка «Нет подключений» вместо списка коннектов
  requireHwid          Boolean                @default(true)
  /// Если true — при наличии HWID в запросе отдаётся заглушка «Отключите HWID»; несовместимо с requireHwid
  requireNoHwid       Boolean                @default(false)
  /// Макс. число уникальных HWID по логам подписки; 0 — не проверять. Запрос с уже зарегистрированным HWID не блокируется. Не действует при включённом requireNoHwid
  maxUniqueHwids      Int                    @default(0)
  /// Ссылка happ://… от crypto.happ.su для шаблонов приложений с плейсхолдером {crypto}; заполняется при создании пользователя
  happCryptoUrl       String?
  /// Секрет для выдачи ленты: GET …/sub/CODE?t=TOKEN (без совпадения — 403). Не отдаётся в API панели.
  subscriptionAccessToken String?
  /// Если true — реальная лента только с альтернативного пути …/sub2128937123/CODE?…&via=crypto-page; обычный /sub/… даёт заглушку «Только Cripto»; happ crypto регистрируется на альтернативный URL
  cryptoOnlySubscription  Boolean              @default(false)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  accessLogs           PanelUserAccessLog[]
}

/// Лог обращения клиента (Happ и др.) к подписке GET /public/sub/:code — IP, HWID, User-Agent, query и заголовки
model PanelUserAccessLog {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  panelUserId   String    @db.ObjectId
  panelUser     PanelUser @relation(fields: [panelUserId], references: [id], onDelete: Cascade)
  /// Клиентский IP (X-Forwarded-For, X-Real-IP, CF-Connecting-IP или сокет)
  clientIp      String?
  userAgent     String?
  /// Идентификатор устройства, если клиент передал (заголовки или query)
  hwid          String?
  accept        String?
  acceptLanguage String?
  referer       String?
  /// Параметры строки запроса (?hwid=…, providerid и т.д.)
  queryParams   Json?
  /// Доп. заголовки (X-*, happ-*, device-* и т.п.), усечённые по длине
  extraHeaders  Json?
  /// false — выдана заглушка (отказ доступа); true — полная лента подписки. Учитывается в лимите HWID и «последней активности».
  success       Boolean   @default(true)
  createdAt     DateTime  @default(now())

  @@index([panelUserId, createdAt])
}

/// Глобальные настройки панели (одна запись с id = "global")
model PanelGlobalSettings {
  id                   String   @id @map("_id")
  /// Текст объявления Happ: в ленту как #announce: base64:… и заголовок announce
  subscriptionAnnounce String?
  /// Интервал автообновления подписки в Happ (часы, целое ≥ 1): #profile-update-interval и заголовок profile-update-interval
  profileUpdateInterval Int?
  /// Токен Telegram-бота (@BotFather); для отправки уведомлений в группу
  telegramBotSecret    String?
  /// ID чата или группы (например -100…), куда бот шлёт сообщения
  telegramGroupId      String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

/// Ссылки для страницы /sub: в urlTemplate {link} → полный URL https://origin/sub/CODE; {crypto} → happCryptoUrl пользователя (если есть); плейсхолдеры необязательны
model SubscriptionAppLink {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  urlTemplate String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

