generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ConnectStatus {
  ACTIVE
  INACTIVE
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  name      String?
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscription {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  title        String
  url          String
  lastFetchedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  connects     Connect[]
}

model Connect {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  originalName   String
  name           String
  groupNames     String[]     @default([])
  raw            String
  protocol       String
  status         ConnectStatus @default(ACTIVE)
  hidden         Boolean      @default(false)
  tags           String[]
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  subscriptionId String       @db.ObjectId
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
}

model Group {
  id                        String   @id @default(auto()) @map("_id") @db.ObjectId
  name                      String   @unique
  /// Название профиля подписки: /sub и profile-title; фрагмент # в ленте — всегда Connect.name
  subscriptionDisplayName   String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model PanelUser {
  id                   String                 @id @default(auto()) @map("_id") @db.ObjectId
  name                 String
  code                 String                 @unique
  groupName            String
  enabled              Boolean                @default(true)
  /// Если true — base64-подписка отдаётся любому User-Agent; иначе только при UA, начинающемся с «Happ»
  allowAllUserAgents   Boolean                @default(false)
  /// Если true — без HWID в запросе отдаётся заглушка «Нет подключений» вместо списка коннектов
  requireHwid          Boolean                @default(true)
  /// Если true — при наличии HWID в запросе отдаётся заглушка «Отключите HWID»; несовместимо с requireHwid
  requireNoHwid       Boolean                @default(false)
  /// Макс. число уникальных HWID по логам подписки; 0 — не проверять. Запрос с уже зарегистрированным HWID не блокируется. Не действует при включённом requireNoHwid
  maxUniqueHwids      Int                    @default(0)
  /// Ссылка happ://… от crypto.happ.su для шаблонов приложений с плейсхолдером {crypto}; заполняется при создании пользователя
  happCryptoUrl       String?
  /// Секрет для выдачи ленты: GET …/sub/CODE?t=TOKEN (без совпадения — 403). Не отдаётся в API панели.
  subscriptionAccessToken String?
  /// Если true — реальная лента только с альтернативного пути …/sub2128937123/CODE?…&via=crypto-page; обычный /sub/… даёт заглушку «Только Cripto»; happ crypto регистрируется на альтернативный URL
  cryptoOnlySubscription  Boolean              @default(false)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  accessLogs           PanelUserAccessLog[]
}

/// Лог обращения клиента (Happ и др.) к подписке GET /public/sub/:code — IP, HWID, User-Agent, query и заголовки
model PanelUserAccessLog {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  panelUserId   String    @db.ObjectId
  panelUser     PanelUser @relation(fields: [panelUserId], references: [id], onDelete: Cascade)
  /// Клиентский IP (X-Forwarded-For, X-Real-IP, CF-Connecting-IP или сокет)
  clientIp      String?
  userAgent     String?
  /// Идентификатор устройства, если клиент передал (заголовки или query)
  hwid          String?
  accept        String?
  acceptLanguage String?
  referer       String?
  /// Параметры строки запроса (?hwid=…, providerid и т.д.)
  queryParams   Json?
  /// Доп. заголовки (X-*, happ-*, device-* и т.п.), усечённые по длине
  extraHeaders  Json?
  /// false — выдана заглушка (отказ доступа); true — полная лента подписки. Учитывается в лимите HWID и «последней активности».
  success       Boolean   @default(true)
  createdAt     DateTime  @default(now())

  @@index([panelUserId, createdAt])
}

/// Ссылки для страницы /sub: в urlTemplate {link} → полный URL https://origin/sub/CODE; {crypto} → happCryptoUrl пользователя (если есть); плейсхолдеры необязательны
model SubscriptionAppLink {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  urlTemplate String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

